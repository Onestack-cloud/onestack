<section class="py-8 lg:py-20" id="savings">
  <div class="container">
    <div class="text-center">
      <h2 class="text-4xl font-semibold" id="calculator">See how much you can save</h2>
      <p class="mt-2 text-lg sm:text-center">
        Discover your savings in seconds. Tell us your team size and software needs.
        We'll show you our straightforward pricing: just $10 per product for every 10 users.
        Plus, see how much you'll save compared to traditional software - both in dollars and percentage.
        Transparent, simple, and cost-effective.
      </p>
    </div>

    <div
      class="mt-12 rounded-lg p-8 bg-secondary/20 text-base-content lg:px-24 lg:py-14"
      x-data="calculator"
    >
      <div class="mt-6 flex justify-center">
        <div class="tabs-boxed bg-secondary/20 tabs">
          <button
            class="tab lg:px-10"
            x-bind:class="{ 'tab-active': searchType === 'products' }"
            @click="searchType = 'products'"
          >
            Products
          </button>
          <button
            class="tab lg:px-10"
            x-bind:class="{ 'tab-active': searchType === 'categories' }"
            @click="searchType = 'categories'"
          >
            Categories
          </button>
        </div>
      </div>

      <div class="mt-6 mx-auto flex flex-wrap justify-center">
        <template x-for="item in itemsToShow" x-bind:key="item">
          <button
            type="button"
            class="inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 border border-gray-600 dark:border-input bg-background hover:bg-primary hover:text-primary-content h-9 px-3 my-1 mx-1"
            x-bind:class="{'bg-primary text-primary-content': selectedItems.includes(item)}"
            @click="toggleItem(item)"
            x-text="item"
          />
        </template>
      </div>

      <div class="mt-6 justify-center">
        <h2 class="card-title">How big is your team?</h2>
        <div class="flex items-center justify-between">
          <input
            id="slider"
            type="range"
            min="1"
            max="30"
            x-model="numUsers"
            class="range w-full"
          />
          <h2 class="ml-4" x-text="numUsers"></h2>
        </div>
      </div>

      <div class="my-12 mx-auto flex justify-center">
        <div class="stats stats-vertical md:stats-horizontal">
          <div class="stat">
            <div class="stat-title">Monthly savings</div>
            <div class="stat-value">$<span x-text="savings.toFixed(2)"></span></div>
            <div class="stat-desc">
              <span x-text="savingsPercent"></span>% saved compared to closed source
            </div>
            <div class="stat-actions">
              <button class="btn btn-primary btn-sm">
                <a href={~p"/users/register"} target="blank">
                  Get started for free
                </a>
              </button>
            </div>
          </div>
          <div class="stat">
            <div class="stat-title">Our price</div>
            <div class="stat-value p mb-16">
              $<span x-text="totalCosts.openSource.toFixed(2)"></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="py-8 lg:py-12 " id="faq">
  <div class="container">
    <div class="text-center">
      <h2 class="text-4xl font-semibold text-base-content">FAQs</h2>
      <p class="mt-2 text-lg">
        Find solutions, tips, and more to enhance your SaaS experience.
      </p>
    </div>

    <div class="mt-12 flex justify-center gap-6">
      <div class="space-y-4 lg:w-1/2">
        <div class="collapse collapse-arrow border border-base-content/10">
          <input checked="checked" name="faq" type="radio" aria-label="open/close" />
          <div class="collapse-title text-xl font-medium">
            How reliable is open-source software?
          </div>
          <div class="collapse-content">
            <p class="text-base">
              Open-source software can be highly reliable. It benefits from community scrutiny, frequent updates, and transparency.
              Many successful businesses rely on open-source solutions for critical operations, demonstrating their dependability and robustness.
            </p>
          </div>
        </div>
        <div class="collapse collapse-arrow border border-base-content/10">
          <input name="faq" type="radio" aria-label="open/close" />
          <div class="collapse-title text-xl font-medium">
            How does Onestack handle data security?
          </div>
          <div class="collapse-content">
            <p class="text-base">
              At Onestack, we prioritise data security. Our platform employs state-of-the-art encryption, strict access controls, and regular security audits to safeguard your data.
              We are actively working towards obtaining SOC2 and ISO 27001 certifications to provide you with additional assurance.
              For more details, please visit our <a class="link" href={~p"/security"}>security</a>
              page.
            </p>
          </div>
        </div>
        <div class="collapse collapse-arrow border border-base-content/10">
          <input name="faq" type="radio" aria-label="open/close" />
          <div class="collapse-title text-xl font-medium">
            Can I remove/add products to my stack?
          </div>
          <div class="collapse-content">
            <p class="text-base">
              Modifying your product stack is straightforward. Simply log in to your account, navigate to "My Stack", and click on the products you wish to add or remove.
              Changes take effect immediately, with any billing adjustments calculated on a pro-rata basis.
            </p>
          </div>
        </div>
        <div class="collapse collapse-arrow border border-base-content/10">
          <input name="faq" type="radio" aria-label="open/close" />
          <div class="collapse-title text-xl font-medium">
            Is there a trial period for Onestack?
          </div>
          <div class="collapse-content">
            <p class="text-base">
              Yes, we offer a free trial period for you to explore and experience our platform's
              features. Use code FREETRIAL when checking out for a 30 day free trial.
            </p>
          </div>
        </div>
        <div class="collapse collapse-arrow border border-base-content/10">
          <input name="faq" type="radio" aria-label="open/close" />
          <div class="collapse-title text-xl font-medium">
            Do you offer enterprise plans?
          </div>
          <div class="collapse-content">
            <p class="text-base">
              For information about our Enterprise offerings, please
              <a class="link" href="https://cal.onestack.cloud/team/onestack">
                schedule a consultation
              </a>
              with our team to discuss your specific requirements.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
  <!-- Modals -->
    <!-- Modal 1 -->
  <div
    id="card1Modal"
    tabindex="-1"
    aria-hidden="true"
    class="fixed top-0 left-0 right-0 z-50 hidden w-full p-4 overflow-x-hidden overflow-y-auto md:inset-0 h-[calc(100%-1rem)] max-h-full"
  >
    <div class="relative w-full max-w-2xl max-h-full">
      <div class="relative bg-gray-900 rounded-2xl shadow-xl">
        <div class="flex items-start justify-between p-6 border-b border-gray-700">
          <h3 class="text-xl font-semibold text-white">Purpose-built for product development</h3>
          <button
            type="button"
            class="text-gray-400 bg-transparent hover:bg-gray-800 rounded-lg text-sm w-8 h-8 inline-flex justify-center items-center"
            data-modal-hide="card1Modal"
          >
            <svg
              class="w-3 h-3"
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 14 14"
            >
              <path
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"
              />
            </svg>
          </button>
        </div>
        <div class="p-6">
          <p class="text-gray-400">Modal content for card 1</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function calculator() {
    return {
      searchType: 'categories',
      numUsers: 1,
      products: <%= Phoenix.HTML.raw(@prepared_products) %>,
      selectedItems: [],

      get categories() {
        return [...new Set(this.products.map(p => p.category))];
      },

      get itemsToShow() {
        return this.searchType === 'products'
          ? this.products.map(p => p.closed_source_name)
          : this.categories;
      },

      toggleItem(item) {
        const index = this.selectedItems.indexOf(item);
        if (index === -1) {
          this.selectedItems.push(item);
        } else {
          this.selectedItems.splice(index, 1);
        }
      },

       get prices() {

        if (this.searchType === 'products') {
          return this.getProductPrices(this.selectedItems);
        } else {
          return this.getAveragePrices(this.selectedItems);
        }
      },

      getProductPrices(products) {
        const prices = this.products.filter(p => products.includes(p.closed_source_name));
        return prices;
      },

      getAveragePrices(categories) {
        const prices = categories.map(category => {
          const categoryProducts = this.products.filter(p => p.category === category);
          const avgClosedSourcePrice = categoryProducts.reduce((sum, p) => sum + p.closed_source_user_price_aud, 0) / categoryProducts.length;
          const avgOpenSourcePrice = categoryProducts.reduce((sum, p) => sum + p.open_source_fixed_price, 0) / categoryProducts.length;
          return {
            category,
            closed_source_user_price_aud: avgClosedSourcePrice,
            open_source_fixed_price: avgOpenSourcePrice
          };
        });
        return prices;
      },

      get totalCosts() {
        const costs = this.prices.reduce((acc, price) => {
          const closedSourceCost = price.closed_source_user_price_aud * this.numUsers;
          const steps = Math.floor((this.numUsers - 1) / 10) + 1;
          const openSourceCost = price.open_source_fixed_price * steps;

          return {
            closedSource: acc.closedSource + closedSourceCost,
            openSource: acc.openSource + openSourceCost
          };
        }, { closedSource: 0, openSource: 0 });

        return costs;
      },

      get savings() {
        const savingsAmount = this.totalCosts.closedSource - this.totalCosts.openSource;
        return isNaN(savingsAmount) ? 0 : savingsAmount;
      },

      get savingsPercent() {
        if (this.totalCosts.closedSource === 0) return "0.00";
        const percent = (this.savings / this.totalCosts.closedSource) * 100;
        return isNaN(percent) ? "0.00" : percent.toFixed(2);
      }
    };
  }
</script>
