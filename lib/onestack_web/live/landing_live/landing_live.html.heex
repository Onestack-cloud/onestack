<section class="relative py-8 lg:py-16 " id="features">
  <div class="absolute start-[10%] z-0">
    <div class="pointer-events-none aspect-square w-60 rounded-full bg-gradient-to-r from-primary/10 via-violet-500/10 to-purple-500/10 blur-3xl [transform:translate3d(0,0,0)] lg:w-[600px]">
    </div>
  </div>

  <div class="container">
    <div class="flex flex-col items-center">
      <h2 class="inline text-4xl font-semibold">Managing SaaS has never been easier</h2>

      <p class="mt-4 text-lg sm:text-center">
        Take back control of your SaaS subscriptions and save hours from setting up your SaaS stack for your team.
      </p>
    </div>

    <div class="relative z-[2] mt-8 grid gap-8 lg:mt-32 lg:grid-cols-2 lg:gap-12">
      <div class="overflow-hidden rounded-lg bg-secondary/20 shadow-md transition-all hover:shadow-xl">
        <img
          src={~p"/images/onestack_manage_light.png"}
          alt="Manage your stack overview"
          class="overflow-hidden rounded-ss-lg dark:hidden"
        />
        <img
          src={~p"/images/onestack_manage_dark.png"}
          alt="Manage your stack overview"
          class="overflow-hidden rounded-ss-lg hidden dark:block"
        />
      </div>

      <div class="lg:mt-8">
        <div class="badge badge-primary">Control</div>
        <h3 class="mt-2 text-3xl font-semibold">Manage your stack</h3>
        <p class="mt-2 text-base font-medium">
          Seamless account and billing management with ability to easily invite your team and modify your stack at any point.
        </p>

        <ul class="mt-4 list-inside list-disc text-base">
          <li>One subscription</li>
          <li>Add or remove products/members with one click</li>
          <li>Intuitive User Interface</li>
          <li>Ability to cancel at any-time</li>
        </ul>
      </div>
    </div>

    <div class="mt-8 grid gap-8 lg:mt-32 lg:grid-cols-2 lg:gap-12">
      <div>
        <div class="badge badge-primary">Features</div>
        <h3 class="mt-2 text-3xl font-semibold">Access to premium features</h3>
        <p class="mt-2 text-base">
          Our SaaS platform offers seamless management, allowing you to effortlessly oversee
          users, projects, and resources in one centralized hub. Gain real-time insights,
          streamline workflows, and optimize resource allocation for unparalleled efficiency.
        </p>

        <ul class="mt-4 list-inside list-disc text-base">
          <li>User-Friendly Tools</li>
          <li>Resource Management</li>
          <li>Task Assignment</li>
          <li>Robust Control</li>
        </ul>
      </div>

      <div class="order-first lg:order-last">
        <div class="overflow-hidden rounded-lg bg-base/20 shadow-md transition-all hover:shadow-xl">
          <img
            src={~p"/images/one_future_light.png"}
            alt="Onestack features"
            class="overflow-hidden rounded-ss-lg dark:hidden"
          />
          <img
            src={~p"/images/one_future_dark.png"}
            alt="Onestack features"
            class="overflow-hidden rounded-ss-lg hidden dark:block"
          />
        </div>
      </div>
    </div>

    <%!-- <div class="mt-8 grid gap-8 lg:mt-20 lg:grid-cols-2 lg:gap-12">
      <div class="overflow-hidden rounded-lg bg-secondary/20 shadow-md transition-all hover:shadow-xl">
        <img
