# Onestack environment configuration
# Copy this file to .env and fill in the values.
#
# Stripe is OPTIONAL. If you leave STRIPE_API_KEY empty, the app will
# boot in self-hosted mode with billing features disabled.

# --- Phoenix / Application ---
# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=
PHX_HOST=localhost
PORT=4000

# --- Stripe (optional) ---
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLIC_KEY=
STRIPE_INDIVIDUAL_PRICE_ID=
STRIPE_TEAM_FEATURES_PRICE_ID=
STRIPE_TEAM_SEATS_PRICE_ID=

# --- Email (Amazon SES) ---
AWS_SES_REGION=
AWS_SES_ACCESS_KEY=
AWS_SES_SECRET=

# --- Matrix / Element integration (optional) ---
MATRIX_API_URL=https://matrix.example.com
MATRIX_REGISTRATION_TOKEN=
MATRIX_WEBHOOK_SECRET=
N8N_MATRIX_RESET_URL=https://n8n.example.com/webhook/matrix/reset_password
N8N_MATRIX_DEACTIVATE_URL=https://n8n.example.com/webhook/matrix/deactivate

# --- Product databases ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=

MARIADB_HOST=localhost
MARIADB_PORT=3306
MARIADB_USER=root
MARIADB_PASSWORD=

# Twenty CRM (separate database)
TWENTY_DB_HOST=localhost
TWENTY_DB_PORT=5432
TWENTY_DB_USER=postgres
TWENTY_DB_PASSWORD=

# --- Production only ---
DATABASE_PATH=
# DNS_CLUSTER_QUERY=
