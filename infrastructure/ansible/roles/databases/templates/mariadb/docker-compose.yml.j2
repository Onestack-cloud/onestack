services:
  mariadb:
    image: "mariadb:{{ mariadb_version }}"
    container_name: mariadb
    environment:
      - MARIADB_ROOT_PASSWORD={{ vault_mariadb_root_password }}
      - MARIADB_DATABASE=default
      - MARIADB_USER={{ vault_mariadb_user }}
      - MARIADB_PASSWORD={{ vault_mariadb_password }}
    restart: unless-stopped
    networks:
      - {{ docker_network_name }}
    labels:
      - "traefik.enable=true"
      - "traefik.tcp.routers.mariadb.rule=HostSNI(`*`)"
      - "traefik.tcp.routers.mariadb.entrypoints=mariadb"
      - "traefik.tcp.services.mariadb.loadbalancer.server.port=3306"
    healthcheck:
      test:
        - CMD
        - healthcheck.sh
        - "--connect"
        - "--innodb_initialized"
      interval: 5s
      timeout: 5s
      retries: 10
      start_period: 5s
    volumes:
      - "{{ databases_dir }}/mariadb/mysql:/var/lib/mysql"

networks:
  {{ docker_network_name }}:
    external: true
