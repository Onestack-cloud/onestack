# Infisical secrets management
# Copy this to .env and fill in the values

# Encryption key for platform encryption/decryption
# Generate with: openssl rand -hex 16
ENCRYPTION_KEY=

# JWT auth secret
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Database connection (shared postgres_db container)
# Create the database first: docker exec postgres_db psql -U onestack-cal -c 'CREATE DATABASE infisical;'
DB_CONNECTION_URI=postgres://onestack-cal:YOUR_PG_PASSWORD@postgres_db:5432/infisical

# Redis connection (shared valkey_redis container, use a unique db number)
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@valkey_redis:6379/5

# Public URL
SITE_URL=https://infisical.onestack.cloud

# Mail/SMTP via AWS SES
SMTP_HOST=email-smtp.ap-southeast-2.amazonaws.com
SMTP_PORT=587
SMTP_FROM_ADDRESS=support@onestack.cloud
SMTP_FROM_NAME=Infisical
SMTP_USERNAME=YOUR_SES_SMTP_USERNAME
SMTP_PASSWORD=YOUR_SES_SMTP_PASSWORD
